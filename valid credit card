import re

n = int(input())

pre_match = r"^[456]\d{3}(-?\d{4}){3}$"
consecutive_match = r"(.)\1{3,}"

for _ in range(n):
    card = input()
    
    if re.match(pre_match, card):
        raw_card = card.replace("-", "")
        if re.search(consecutive_match, raw_card):
            print("Invalid")
        else:
            print("Valid")
    else:
        print("Invalid")
